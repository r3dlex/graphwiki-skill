{
  "version": "2.0",
  "provider": "anthropic",
  "provider_config": {
    "model": "claude-sonnet-4-20250514",
    "max_tokens": 4096
  },
  "extraction": {
    "languages": ["typescript", "python", "go", "rust", "elixir"],
    "ignore_patterns": ["node_modules/**", "dist/**", ".git/**", "*.lock"],
    "rationale_markers": ["WHY:", "HACK:", "IMPORTANT:", "TODO:", "FIXME:"],
    "max_file_size_kb": 500,
    "max_document_pages": 50,
    "chunk_overlap_pages": 2,
    "extraction_budget_tokens": 500000,
    "max_single_file_tokens": 80000,
    "retry_failed_on_model_update": true,
    "skip_unsupported_formats": false,
    "validation_mode": "strict",
    "max_retries_per_file": 3,
    "initial_parallelism": 3,
    "min_parallelism": 1,
    "backoff_base_ms": 1000,
    "backoff_max_ms": 60000,
    "backoff_multiplier": 2.0,
    "circuit_breaker_threshold": 5,
    "circuit_breaker_reset_ms": 120000,
    "resume_enabled": true
  },
  "dedup": {
    "enabled": true,
    "merge_threshold": 0.85,
    "model": "all-MiniLM-L6-v2",
    "context_window": 3
  },
  "clustering": {
    "algorithm": "leiden",
    "resolution": 1.0,
    "drift_threshold": 0.15,
    "max_scoped_runs": 20
  },
  "wiki": {
    "max_tokens_per_page": 5000,
    "stage2_threshold_nodes": 15,
    "compilation_budget": 100000,
    "parallel_compilations": 3
  },
  "query": {
    "default_budget": 10000,
    "max_hops": 3,
    "cache_enabled": true,
    "cache_ttl_hours": 168
  },
  "serve": {
    "transport": "stdio",
    "http_port": 8080,
    "cors_origins": ["http://localhost:*"]
  },
  "benchmark": {
    "baselines": ["grep_assisted", "rag", "naive"],
    "corpus_path": "tests/fixtures/mixed-corpus"
  },
  "refine": {
    "enabled": true,
    "max_cycles": 3,
    "failure_threshold": 0.6,
    "max_prompt_diff_chars": 200,
    "total_budget_tokens": 100000,
    "run_on_full_build": true,
    "run_on_incremental": false,
    "held_out_path": ".graphwiki/held-out-queries.json"
  }
}
