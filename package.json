{
  "name": "graphwiki",
  "version": "2.0.0",
  "description": "LLM-powered knowledge graph builder with persistent wiki compilation and Claude Code context loading protocol",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "graphwiki": "./dist/cli.js"
  },
  "files": [
    "dist",
    "lib",
    "SKILL.md",
    "SKILL-claude.md",
    "SKILL-codex.md",
    "SKILL-copilot.md",
    "SKILL-gemini.md",
    "SKILL-cursor.md",
    "SKILL-openclaw.md",
    "SKILL-auggie.md",
    "SKILL-windsurf.md",
    "SKILL-cody.md",
    "SKILL-codewhisperer.md",
    "scripts"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "fmt": "prettier --write src",
    "test": "vitest",
    "test:unit": "vitest --coverage --coverage.thresholds.lines=90 --coverage.thresholds.branches=85",
    "test:integration": "vitest tests/integration",
    "test:benchmark": "vitest tests/benchmark",
    "test:watch": "vitest --watch",
    "generate:skills": "tsx src/hooks/skill-generator.ts",
    "prepublishOnly": "pnpm run build && pnpm run generate:skills",
    "release": "changesets publish"
  },
  "keywords": [
    "knowledge-graph",
    "llm",
    "wiki",
    "mcp",
    "tree-sitter",
    "graph",
    "knowledge-base"
  ],
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "commander": "^12.0.0",
    "express": "^4.21.0",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "neo4j-driver": "^5.27.0",
    "chokidar": "^4.0.0",
    "onnxruntime-node": "^1.20.0",
    "pdfjs-dist": "^4.9.0",
    "tree-sitter": "^0.22.0",
    "web-tree-sitter": "^0.26.8",
    "xxhash-wasm": "^1.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "tiktoken": "^1.0.13",
    "tree-sitter-bash": "^0.23.0",
    "tree-sitter-c": "^0.23.0",
    "tree-sitter-c-sharp": "^0.23.0",
    "tree-sitter-cpp": "^0.23.0",
    "tree-sitter-go": "^0.23.0",
    "tree-sitter-java": "^0.23.0",
    "tree-sitter-python": "^0.23.0",
    "tree-sitter-rust": "^0.23.0",
    "tree-sitter-typescript": "^0.23.0",
    "ts-morph": "^25.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^3.0.0",
    "archgate": "0.27.0"
  }
}
